    {
      "id": "TKLzXO_m247f0zzIlUrsM",
      "type": "text",
      "x": -131.35112773648478,
      "y": 2966.93394259021,
      "width": 499,
      "height": 247.5,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
