      "roundness": null,
      "seed": 1714083962,
      "version": 433,
      "versionNonce": 1151713318,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775684311363,
      "link": null,
      "locked": false,
      "text": "try / except\n\n- try: tenta executar o bloco\n- except: se der erro, faz isso no lugar de travar\n- ValueError: erro ao converter tipo errado (ex:\nfloat(\"abc\"))\n\nExemplo:\n  while True:\n      try:\n          peso = float(input(\"Peso: \"))\n          break\n      except ValueError:\n          print(\"Digite um numero!\")",
      "fontSize": 18,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "gS_LIipplijHGqiC-mhan",
      "originalText": "try / except\n\n- try: tenta executar o bloco\n- except: se der erro, faz isso no lugar de travar\n- ValueError: erro ao converter tipo errado (ex: float(\"abc\"))\n\nExemplo:\n  while True:\n      try:\n          peso = float(input(\"Peso: \"))\n          break\n      except ValueError:\n          print(\"Digite um numero!\")",
      "autoResize": true,
      "lineHeight": 1.25
    },
