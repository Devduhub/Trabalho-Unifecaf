      "isDeleted": false,
      "boundElements": [],
      "updated": 1775683305935,
      "link": null,
      "locked": false,
      "text": "SERVE PARA USAR UMA\nVARIAVEL QUE JA TEM E QUE\nPRECISA TER MODIFICAÇÃO\n\nEX : SEM A FUNÇÃO GLOBAL \n\nNOME = '' EDUARDO''\nPRINT(' EUDARDO')\n\n/\\\nl\nAPENAS VISUALIZA SEM\nALTERAR\n\n------------------------------------\n\nUSANDO A FUNÇÃO GLOBAL\n\nNOME = '' EDUARDO''\nGLOBAL NOME\nNOME = JOSE\n\n\nCHAMOU A VARIAVEL\nUSOU A FUNÇÃO GLOBAL E\nFALOU QUAL VARIAVEL SERIA\nMODIFICADA\nAPOS ISSO PUXOU A VARIAVEL E\nFEZ A MODIFICAÇÃO\n\n/\\\nl\n \n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "vDZlsBuEHMh_1OHV44pkY",
      "originalText": "SERVE PARA USAR UMA VARIAVEL QUE JA TEM E QUE PRECISA TER MODIFICAÇÃO\n\nEX : SEM A FUNÇÃO GLOBAL \n\nNOME = '' EDUARDO''\nPRINT(' EUDARDO')\n\n/\\\nl\nAPENAS VISUALIZA SEM ALTERAR\n\n------------------------------------\n\nUSANDO A FUNÇÃO GLOBAL\n\nNOME = '' EDUARDO''\nGLOBAL NOME\nNOME = JOSE\n\n\nCHAMOU A VARIAVEL\nUSOU A FUNÇÃO GLOBAL E FALOU QUAL VARIAVEL SERIA MODIFICADA\nAPOS ISSO PUXOU A VARIAVEL E FEZ A MODIFICAÇÃO\n\n/\\\nl\n \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
