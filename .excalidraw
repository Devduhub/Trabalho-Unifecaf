      "text": "Fluxo: validar ID\n\n  while True:\n      pede o ID\n      se vazio -> continue (repete)\n      se ja existe -> continue (repete)\n      break <- ID valido e novo",
      "fontSize": 18,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "N6vRhct4__m8MC862tPDy",
      "originalText": "Fluxo: validar ID\n\n  while True:\n      pede o ID\n      se vazio -> continue (repete)\n      se ja existe -> continue (repete)\n      break <- ID valido e novo",
      "autoResize": true,
      "lineHeight": 1.25
    },
