    {
      "id": "8Stci8qgmcX_85-idANmJ",
      "type": "text",
      "x": -131.35112773648478,
      "y": 3366.93394259021,
      "width": 427,
      "height": 315,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
